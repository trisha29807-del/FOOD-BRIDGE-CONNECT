<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5EE">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="56dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profile"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#222222"
                android:layout_marginBottom="16dp" />

            <!-- Profile Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="24dp">

                    <!-- Avatar -->
                    <TextView
                        android:id="@+id/tvAvatar"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:text="FB"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:gravity="center"
                        android:background="@drawable/circle_avatar_bg" />

                    <!-- Name -->
                    <TextView
                        android:id="@+id/tvProfileName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FoodBridge User"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#222222"
                        android:layout_marginTop="12dp" />

                    <!-- Role -->
                    <TextView
                        android:id="@+id/tvProfileRole"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Donor · Mumbai, India"
                        android:textSize="13sp"
                        android:textColor="#888888"
                        android:layout_marginTop="4dp" />

                    <!-- Star Rating -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="⭐" android:textSize="16sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="4.8 (24 reviews)" android:textSize="13sp"
                            android:textColor="#888888" android:layout_marginStart="4dp" />
                    </LinearLayout>

                    <!-- Edit Profile Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEditProfile"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="Edit Profile"
                        android:textSize="13sp"
                        android:textColor="#2E7D32"
                        app:backgroundTint="#E8F5E9"
                        app:strokeColor="#2E7D32"
                        app:strokeWidth="1dp"
                        app:cornerRadius="20dp"
                        android:layout_marginTop="14dp"
                        android:stateListAnimator="@null" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Stats Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3"
                android:layout_marginBottom="16dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:gravity="center" android:padding="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="📦" android:textSize="24sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="12" android:textSize="20sp" android:textStyle="bold"
                            android:textColor="#222222" android:layout_marginTop="4dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Donations" android:textSize="11sp" android:textColor="#888888" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:gravity="center" android:padding="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="❤️" android:textSize="24sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="340" android:textSize="20sp" android:textStyle="bold"
                            android:textColor="#222222" android:layout_marginTop="4dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Meals Shared" android:textSize="11sp" android:textColor="#888888" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:gravity="center" android:padding="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🔔" android:textSize="24sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="5" android:textSize="20sp" android:textStyle="bold"
                            android:textColor="#222222" android:layout_marginTop="4dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Notifications" android:textSize="11sp" android:textColor="#888888" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- Account Info Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Account Info" android:textSize="15sp" android:textStyle="bold"
                        android:textColor="#222222" android:layout_marginBottom="8dp" />

                    <!-- Email Row -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:paddingTop="10dp" android:paddingBottom="10dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="✉️" android:textSize="18sp" />
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical"
                            android:layout_marginStart="12dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Email" android:textSize="11sp" android:textColor="#888888" />
                            <TextView android:id="@+id/tvProfileEmail"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="user@example.com" android:textSize="14sp" android:textColor="#222222" />
                        </LinearLayout>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#F0F0F0" />

                    <!-- Role Row -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:paddingTop="10dp" android:paddingBottom="10dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🏷️" android:textSize="18sp" />
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical"
                            android:layout_marginStart="12dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Role" android:textSize="11sp" android:textColor="#888888" />
                            <TextView android:id="@+id/tvProfileRoleInfo"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Donor / Seller" android:textSize="14sp" android:textColor="#222222" />
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- My Activity Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="My Activity" android:textSize="15sp" android:textStyle="bold"
                        android:textColor="#222222" android:layout_marginBottom="8dp" />

                    <!-- My Donations -->
                    <LinearLayout android:id="@+id/rowMyDonations"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:paddingTop="10dp" android:paddingBottom="10dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🍱" android:textSize="18sp" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="My Donations"
                            android:textSize="14sp" android:textColor="#222222" android:layout_marginStart="12dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="→" android:textSize="18sp" android:textColor="#AAAAAA" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#F0F0F0" />

                    <!-- My Orders -->
                    <LinearLayout android:id="@+id/rowMyOrders"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:paddingTop="10dp" android:paddingBottom="10dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🛒" android:textSize="18sp" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="My Orders"
                            android:textSize="14sp" android:textColor="#222222" android:layout_marginStart="12dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="→" android:textSize="18sp" android:textColor="#AAAAAA" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#F0F0F0" />

                    <!-- History -->
                    <LinearLayout android:id="@+id/rowHistory"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:paddingTop="10dp" android:paddingBottom="10dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="📋" android:textSize="18sp" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="History"
                            android:textSize="14sp" android:textColor="#222222" android:layout_marginStart="12dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="→" android:textSize="18sp" android:textColor="#AAAAAA" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- FSSAI Guidelines -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout android:id="@+id/rowFssai"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="⚙️" android:textSize="22sp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="FSSAI Guidelines"
                        android:textSize="15sp" android:textColor="#222222" android:layout_marginStart="12dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="→" android:textSize="18sp" android:textColor="#AAAAAA" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Sign Out Button -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:id="@+id/btnSignOut"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:padding="16dp">
                    <TextView android:id="@+id/tvSignOutIcon"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="↪" android:textSize="18sp" android:textColor="#C62828" />
                    <TextView android:id="@+id/tvSignOutText"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Sign Out" android:textSize="15sp" android:textStyle="bold"
                        android:textColor="#C62828" android:layout_marginStart="8dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="bottom"
        android:background="#FFFFFF"
        app:itemIconTint="#2E7D32"
        app:itemTextColor="#2E7D32"
        app:menu="@menu/bottom_nav_menu" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>